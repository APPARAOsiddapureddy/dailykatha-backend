NODE_ENV=development
ENVIRONMENT=development
PORT=3000

# Postgres — local Docker Compose maps 15432→5432 (see backend/docker-compose.yml)
# DATABASE_URL=postgresql://dailykatha:dailykatha@127.0.0.1:15432/dailykatha

# Managed / production
DATABASE_URL=postgresql://user:pass@host:5432/dailykatha

# Redis — local Docker Compose maps 16379→6379
# REDIS_URL=redis://127.0.0.1:16379

REDIS_URL=redis://host:6379

# JWT
JWT_SECRET=your-secret-key-here

# CORS allowlist (comma-separated)
CORS_WHITELIST=https://app.dailykatha.com,https://admin.dailykatha.com

# Logging
LOG_LEVEL=info
SERVICE_NAME=daily-katha-api
APP_VERSION=1.0.0

# Observability
SENTRY_DSN=https://your-sentry-dsn

# Rate limiting
API_RATE_LIMIT=100

