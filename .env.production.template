# Copy to Render → Environment (never commit real secrets).
# Renamed from `.env.production` so git never tracks credentials.

NODE_ENV=production
ENVIRONMENT=production
PORT=3000

DATABASE_URL=postgresql://USER:PASSWORD@HOST-pooler.region.aws.neon.tech/neondb?sslmode=require

# Optional — caching, BullMQ, feed cache
# REDIS_URL=rediss://default:xxx@host:6379

JWT_SECRET=replace_with_openssl_rand_hex_32

# OTP (seconds) — app code uses 600; keep in sync with mobile if you add this to API
# OTP_TTL_SECONDS=600

# Meta WhatsApp Cloud API
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_OTP_TEMPLATE_NAME=daily_katha_otp
WHATSAPP_TEMPLATE_LANGUAGE=en
# Dev/staging: log OTP without sending
# OTP_ALLOW_WITHOUT_WHATSAPP=true

# QA: 123456xxxx + fixed OTP — OFF in production unless explicitly enabled
ENABLE_QA_SHORTCUTS=false

# CORS for browser clients (comma-separated). Mobile apps often send no Origin.
CORS_WHITELIST=https://dailykatha-app.web.app,https://dailykatha.com

SENTRY_DSN=
APP_VERSION=1.0.0
LOG_LEVEL=info

# Internal routes / metrics
# INTERNAL_API_KEY=
