{
  "name": "daily-katha-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "node src/app.js",
    "dev": "node --watch src/app.js",
    "legacy:start": "node src/server.js",
    "worker": "node src/workers/generationWorker.js",
    "migrate:legacy": "node src/db/migrate.js",
    "seed-indexes:legacy": "node src/db/indexes.js",
    "migrate": "node scripts/run-pg-migrate.mjs up",
    "migrate:down": "node scripts/run-pg-migrate.mjs down",
    "migrate:prod": "node scripts/run-pg-migrate.mjs up",
    "lint": "node -c src/app.js >/dev/null",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest --config jest.config.cjs",
    "test:integration": "NODE_OPTIONS=--experimental-vm-modules jest --config jest.integration.config.cjs",
    "test:e2e": "NODE_OPTIONS=--experimental-vm-modules jest --config jest.e2e.config.cjs",
    "build": "node -c src/app.js >/dev/null"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "@sentry/node": "^8.0.0",
    "bullmq": "^5.34.5",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-validator": "^7.2.0",
    "express-rate-limit": "^7.4.0",
    "helmet": "^8.1.0",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "node-pg-migrate": "^7.9.1",
    "pino": "^9.7.0",
    "pino-http": "^9.0.0",
    "node-cron": "^4.0.7",
    "pg": "^8.13.1",
    "rate-limit-redis": "^4.3.1",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^11.0.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "supertest": "^7.1.4"
  }
}
